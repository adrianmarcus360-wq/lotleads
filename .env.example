// =============================================================
// DATABASE
// =============================================================
DATABASE_URL="postgresql://user:password@host:5432/lotleads?sslmode=require"

// =============================================================
// AUTH (NextAuth)
// =============================================================
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Google OAuth (adds Google sign-in button)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Optional: magic-link email (add Resend or SendGrid)
# EMAIL_FROM="noreply@yourdomain.com"
# RESEND_API_KEY=""

// =============================================================
// STRIPE
// =============================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Product/Price IDs (created by: npm run stripe:setup)
STRIPE_PRICE_SHARED_LEAD="price_shared_..."
STRIPE_PRICE_EXCLUSIVE_LEAD="price_exclusive_..."
STRIPE_PRICE_PRO_MONTHLY="price_pro_..."

// =============================================================
// MAPS / IMAGERY
// =============================================================
# Google Maps Static API (for aerial images)
GOOGLE_MAPS_API_KEY=""

# Mapbox (fallback - free 50k/mo)
NEXT_PUBLIC_MAPBOX_TOKEN=""

// =============================================================
// ADMIN
// =============================================================
ADMIN_EMAIL="your@email.com"

// =============================================================
// APP
// =============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="LotLeads"

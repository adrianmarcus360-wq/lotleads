// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  company       String?
  phone         String?
  passwordHash  String?
  role          UserRole  @default(BUYER)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  purchases    Purchase[]
  subscription Subscription?
  credits      LeadCredit[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// LEADS
// ─────────────────────────────────────────────

model Lead {
  id          String     @id @default(cuid())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Location
  address     String
  city        String
  state       String
  zip         String
  lat         Float
  lng         Float

  // Property
  propertyName    String?
  lotSqFt         Int?
  propertyType    PropertyType @default(COMMERCIAL_PARKING)

  // Condition
  conditionScore  Int    // 1-10 (10 = worst / most urgent)
  damageTypes     String // JSON array: ["cracks","potholes","fading","drainage"]
  estimatedJobMin Int    // USD
  estimatedJobMax Int    // USD
  urgency         Urgency @default(MEDIUM)

  // Imagery
  aerialImageUrl  String?
  blurredImageUrl String?
  lat1            Float?  // bounding box for tile fetch
  lng1            Float?
  lat2            Float?
  lng2            Float?

  // Contact (locked until purchase)
  propertyManagerName  String?
  propertyManagerEmail String?
  propertyManagerPhone String?
  propertySource       String?  // "assessor", "yelp", "manual"

  // Availability
  status            LeadStatus @default(AVAILABLE)
  vertical          Vertical[]
  sharedBuyerCount  Int        @default(0)
  maxSharedBuyers   Int        @default(3)
  exclusiveBuyerId  String?
  exclusiveExpiresAt DateTime?

  // Market
  market    String  // "chicago_il", "dallas_tx", "phoenix_az"

  purchases Purchase[]
}

model Purchase {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())

  userId    String
  leadId    String
  type      PurchaseType // SHARED | EXCLUSIVE
  amount    Int          // cents
  status    PaymentStatus @default(PENDING)

  stripePaymentIntentId String? @unique
  stripeSessionId       String? @unique

  user User @relation(fields: [userId], references: [id])
  lead Lead @relation(fields: [leadId], references: [id])

  @@unique([userId, leadId])
}

model Subscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String @unique
  user     User   @relation(fields: [userId], references: [id])

  stripeSubscriptionId String  @unique
  stripeCustomerId     String?
  status               SubStatus @default(ACTIVE)
  currentPeriodEnd     DateTime

  plan              SubPlan @default(PRO)
  leadsPerMonth     Int     @default(5)
  leadsRemaining    Int     @default(5)
  leadsResetAt      DateTime?

  territory  String?   // "chicago_il" — locked zip/city
  markets    String[]  // markets included in plan

  credits LeadCredit[]
}

model LeadCredit {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String
  subscriptionId String?
  amount     Int      // number of leads
  reason     String   // "monthly_reset", "promo", "refund"
  user       User     @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
}

// ─────────────────────────────────────────────
// PROSPECTS (paving/striping company outreach list)
// ─────────────────────────────────────────────

model Prospect {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyName   String
  vertical      String  // "paving" | "striping" | "both"
  email         String?
  phone         String?
  website       String?
  address       String?
  city          String
  state         String
  market        String

  // Outreach tracking
  outreachStatus  OutreachStatus @default(NOT_CONTACTED)
  lastContactedAt DateTime?
  convertedAt     DateTime?
  notes           String?

  source  String  // "yelp", "google", "scraped"
  yelpId  String?
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  BUYER
  ADMIN
}

enum PropertyType {
  COMMERCIAL_PARKING
  RETAIL_STRIP
  OFFICE_PARK
  INDUSTRIAL
  MIXED_USE
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LeadStatus {
  AVAILABLE
  PARTIALLY_SOLD  // 1-2 shared buyers
  SOLD_SHARED     // 3 shared buyers (maxed)
  SOLD_EXCLUSIVE
  EXPIRED
}

enum Vertical {
  PAVING
  STRIPING
}

enum PurchaseType {
  SHARED
  EXCLUSIVE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum SubPlan {
  PRO
}

enum OutreachStatus {
  NOT_CONTACTED
  EMAILED
  OPENED
  CLICKED
  REPLIED
  DEMO_SCHEDULED
  CONVERTED
  UNSUBSCRIBED
}
